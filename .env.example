# Runtime environment name, such as local, staging, or production.
ENV_NAME=local
# Full Postgres connection string for Supabase or local Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mediator
# Postgres schema used by the app tables. Use a dedicated schema when sharing a Supabase project.
DATABASE_SCHEMA=public
# Supabase project API URL.
SUPABASE_URL=https://example.supabase.co
# Supabase service-role key for backend-only DB access.
SUPABASE_SERVICE_ROLE_KEY=
# Anthropic API key for text LLM calls.
ANTHROPIC_API_KEY=
# DeepSeek API key for optional named-user conversational calls.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# OpenAI API key for vision calls.
OPENAI_API_KEY=
# Groq API key for transcription calls.
GROQ_API_KEY=
# WhatsApp Cloud API bearer token.
WHATSAPP_TOKEN=
# WhatsApp Cloud API phone number ID.
WHATSAPP_PHONE_NUMBER_ID=
# WhatsApp webhook verify token.
WHATSAPP_VERIFY_TOKEN=
# WhatsApp app secret for webhook signature validation.
WHATSAPP_APP_SECRET=
# Messaging provider: "meta" for direct WhatsApp Cloud API, "twilio" for Twilio WhatsApp/Sandbox,
# or "discord" for a Discord bot DM transport.
MESSAGING_PROVIDER=meta
# Twilio Account SID, Auth Token, and WhatsApp sender. Required only when MESSAGING_PROVIDER=twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Optional preferred Twilio API Key credentials for REST API auth. Keep TWILIO_ACCOUNT_SID set.
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Optional exact public Twilio webhook URL for signature validation behind proxies/tunnels.
TWILIO_WEBHOOK_URL=
# Discord bot token. Required only when MESSAGING_PROVIDER=discord.
DISCORD_BOT_TOKEN=
# Discord user IDs allowed to talk to the bot. Required when MESSAGING_PROVIDER=discord.
DISCORD_PARTNER_USER_ID_A=
DISCORD_PARTNER_USER_ID_B=
DISCORD_PARTNER_NAME_A=Partner A
DISCORD_PARTNER_NAME_B=Partner B
# Password for read-only admin pages.
ADMIN_PASSWORD=
# First allowed partner phone number, digits only or E.164.
PARTNER_PHONE_A=15555550100
# Second allowed partner phone number, digits only or E.164.
PARTNER_PHONE_B=15555550101
# Daily text LLM spend warning threshold in USD. Hard caps are disabled in code.
TEXT_LLM_DAILY_CAP_USD=10.0
# Daily vision spend warning threshold in USD. Hard caps are disabled in code.
VISION_DAILY_CAP_USD=2.0
# Daily transcription spend warning threshold in USD. Hard caps are disabled in code.
TRANSCRIPTION_DAILY_CAP_USD=1.0
# Conversational loop model.
CONVERSATIONAL_MODEL=claude-sonnet-4-6
DEEPSEEK_CONVERSATIONAL_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_ENABLED=false
DEEPSEEK_REASONING_EFFORT=
LIVE_VOICE_STT_PROVIDER=groq
LIVE_VOICE_TURN_PROVIDER=deepseek
LIVE_VOICE_PREP_PROVIDER=agentic
# Set to true to require a valid Bearer JWT on live-voice HTTP routes and the WS.
# Leave false during local dev to use LIVE_VOICE_TEST_USER_ID as the caller.
LIVE_VOICE_AUTH_ENABLED=false
# Dedicated OOB checker model.
OOB_CHECKER_MODEL=claude-sonnet-4-6
# Observation scoring and OOB topic clustering model.
SCORING_MODEL=claude-haiku-4-5-20251001
# Assistant display name rendered into prompts.
ASSISTANT_NAME=the assistant
# Approximate hot-context prompt budget.
HOT_CONTEXT_TOKEN_BUDGET=6000
# Bot profile consumed by the shared agentic runner.
BOT_ID=mediator
# System prompt version stored with bot turns.
SYSTEM_PROMPT_VERSION=v1
# Scheduler worker enable flag and cadence.
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL_S=10
SCHEDULER_BATCH_SIZE=10
# Discord pacing controls. Used only by the Discord transport when pacing is enabled.
DISCORD_PACING_ENABLED=true
DISCORD_PACING_BURST_WINDOW_S=2.75
DISCORD_PACING_INITIAL_TYPING_MIN_S=0.5
DISCORD_PACING_INITIAL_TYPING_MAX_S=2.5
DISCORD_PACING_MIN_WAIT_S=0.8
DISCORD_PACING_MAX_WAIT_S=12
DISCORD_PACING_TYPING_GRACE_S=4
DISCORD_PACING_TYPING_EXTEND_S=2
DISCORD_PACING_MAX_TYPING_WAIT_S=20
DISCORD_PACING_ANSWER_TYPING_MIN_S=1
DISCORD_PACING_ANSWER_TYPING_MAX_S=14
DISCORD_PACING_ANSWER_CHARS_PER_S=18
DISCORD_PACING_COMPOSITION_JITTER_RATIO=0
DISCORD_PACING_TYPING_PULSE_MIN_GAP_S=11
DISCORD_PACING_TYPING_VISIBLE_S=8
DISCORD_PACING_TYPING_OFF_GAP_S=3
DISCORD_PACING_REACTIONS_ENABLED=true
DISCORD_PACING_REACTION_COOLDOWN_S=180
DISCORD_PACING_REACTION_DAILY_LIMIT=12
DISCORD_PACING_SILENCE_COOLDOWN_S=300
DISCORD_PACING_LLM_JUDGEMENT_ENABLED=true
DISCORD_PACING_LLM_MIN_AMBIGUITY=0.45
DISCORD_PACING_EVENT_RETENTION_DAYS=30
# Inbound queue: max age in days for unprocessed inbound messages before expiry.
# Messages older than this are marked expired instead of retried.
INBOUND_QUEUE_RETENTION_DAYS=7
# Inbound queue: max automatic retry attempts for failed messages.
# Once exceeded, messages are left in terminal failed state for manual inspection.
INBOUND_QUEUE_MAX_RETRY_ATTEMPTS=3
# Recovery-v2: base/cap (seconds) for the SET-time CASE backoff applied in
# inbound_queue.fail_messages when failure_class='retryable_pre_send'.
# next_retry_at = now() + min(base * 2^(processing_attempts-1), cap).
RECOVERY_V2_RETRY_BASE_SECONDS=15
RECOVERY_V2_RETRY_CAP_SECONDS=600
# Project A2 provider robustness: max Retry-After value (seconds) honoured
# in-band before advancing to the next provider hop.
PROVIDER_RETRY_AFTER_CAP_SECONDS=30
# Sliding window (seconds) for the per-bot fallback-rate circuit breaker.
PROVIDER_FALLBACK_BREAKER_WINDOW_SECONDS=300
# Fall-back rate that trips the per-bot breaker open (0.0–1.0).
PROVIDER_FALLBACK_BREAKER_THRESHOLD=0.5
# Minimum sample count before the breaker is allowed to trip.
PROVIDER_FALLBACK_BREAKER_MIN_SAMPLES=10
# Per-call provider HTTP timeout (seconds) applied to the DeepSeek client.
PROVIDER_CALL_TIMEOUT_SECONDS=120
# Weekly summary defaults; Sunday is 0, Monday is 1.
WEEKLY_SUMMARY_DEFAULT_DAY=1
WEEKLY_SUMMARY_DEFAULT_TIME=09:00
# Heartbeat cadence for cron-ping monitoring.
HEARTBEAT_INTERVAL_HOURS=24
# Supabase Storage bucket and media timeout.
SUPABASE_STORAGE_BUCKET=mediator-media
MEDIA_FETCH_TIMEOUT_S=30
# Sonnet-family input price per million tokens.
ANTHROPIC_INPUT_USD_PER_MTOK=3.0
# Sonnet-family output price per million tokens.
ANTHROPIC_OUTPUT_USD_PER_MTOK=15.0
# Haiku-family input price per million tokens.
ANTHROPIC_HAIKU_INPUT_USD_PER_MTOK=1.0
# Haiku-family output price per million tokens.
ANTHROPIC_HAIKU_OUTPUT_USD_PER_MTOK=5.0
# DeepSeek input/output prices per million tokens.
DEEPSEEK_INPUT_USD_PER_MTOK=0.27
DEEPSEEK_OUTPUT_USD_PER_MTOK=1.10
# Optional Sentry DSN for error reporting.
SENTRY_DSN=
# Optional log destination identifier or URL.
LOG_DESTINATION=
# Base64-encoded 32-byte key for column-level encryption of sensitive content.
DATA_ENCRYPTION_KEY=
